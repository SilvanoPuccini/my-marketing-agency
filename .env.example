# ============================================================
# My Marketing Agency — Variables de entorno
# Copiá este archivo a .env.local y completá los valores
# ============================================================

# Supabase — Settings > API en tu dashboard de Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...tu-anon-key...   # la copiá de Supabase > Settings > API

# ─────────────────────────────────────────────────────────
# NOTA: Las variables que comienzan con VITE_ son públicas
#       y se incluyen en el bundle de producción.
#       NO pongas secrets privadas (API keys de Stripe,
#       service role keys, etc.) con prefijo VITE_.
#       Esas van en los secrets del backend (Supabase Edge
#       Functions, Vercel Environment Variables).
# ─────────────────────────────────────────────────────────
